{
  "default": "gitlab-app",
  "items": {
    "gitlab-app": {
      "path": "/absolute/path/to/your/repo",
      "scm": "git",
      "base": "origin/main",
      "target_branch": "main",
      "push_enabled": false,
      "pr_enabled": false,
      "pr_provider": "gitlab",
      "gitlab_repo": "group/project",
      "test_cmd": ""
    },
    "svn-app": {
      "path": "/absolute/path/to/local/svn-checkout-or-placeholder",
      "scm": "svn",
      "base": "https://svn.example.com/repos/project/trunk",
      "push_enabled": false,
      "test_cmd": ""
    }
  }
}
