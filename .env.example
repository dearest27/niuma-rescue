# 复制为 .env 并填好（.env 已被 gitignore，不会提交）。
# 只有这里的"部署相关"值需要每个部署者自己设；字段名/状态/引擎命令在 config.py 里是固定契约。

# —— 飞书 app 凭据（必填）——
# 开发者后台建自建应用，开 bitable + im 权限。bootstrap 和数据层都用它。
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# —— 飞书多维表格（必填）——
# bootstrap.py 建表后会把这两个写回来；手动建表则从表格 URL 取 app_token 和 table_id。
PIPELINE_BASE_TOKEN=app_token_xxx
PIPELINE_TABLE_ID=tblxxx

# —— 目标代码仓库（必填）——
# agent 在这里改代码、建 worktree；需是 git 仓库且有 origin/main。
PIPELINE_REPO_PATH=/abs/path/to/your/repo
# 工作区映射文件，默认 ./workspaces.json
# PIPELINE_WORKSPACES_FILE=
# 飞书字段映射文件，默认 ./fields.json；复制 fields.example.json 后可按你的 Base 列名调整。
# PIPELINE_FIELDS_FILE=
# Agent 命令/别名配置文件，默认 ./agents.json；复制 agents.example.json 后可覆盖默认命令。
# PIPELINE_AGENTS_FILE=

# —— 以下都可选，留空用默认 ——

# 自动 push/PR 开关。默认关闭，适合本地验证；GitHub/GitLab PR/MR 或 SVN commit 可在 workspaces.json 里按工作区打开。
PIPELINE_PUSH_ENABLED=0
PIPELINE_PR_ENABLED=0

# GitHub PR 目标仓库（org/repo），仅 pr_provider=github 且 PIPELINE_PR_ENABLED=1 时使用。
PIPELINE_GH_REPO=

# 验收门 shell：在 worktree 里执行，exit 0 视为通过。留空则不跑验收门。
# 例：PIPELINE_TEST_CMD=npm test     例：PIPELINE_TEST_CMD=pytest -q
# PIPELINE_TEST_CMD=

# worktree 根目录（默认 <pipeline>/worktrees）
# PIPELINE_WORKTREE_BASE=

# 轮询间隔秒（默认 900；事件驱动为主，轮询只做兜底；测试可临时调小如 25）
# PIPELINE_POLL_INTERVAL=900

# 并发与熔断
# PIPELINE_MAX_CONCURRENCY=1
# PIPELINE_FAILURE_LIMIT=2
# 记录级执行锁过期秒数；默认比单次 agent 超时多 10 分钟。
# PIPELINE_EXECUTION_STALE_AFTER=7800
# 失败后重试退避基数秒数，实际退避为 60/120/240...，最多 15 分钟。
# PIPELINE_RETRY_BASE_DELAY=60
# 卡死看门狗：cursor 多久没有任何输出事件就判定卡死并杀掉重试（秒，0 关闭）。
# 偶发静默卡死从此 ~2min 自愈，而非干等到总超时。正常思考间隙约 10s。
# PIPELINE_INACTIVITY_TIMEOUT=120
# 飞书实时进度卡片：运行中原地更新一张卡片的最小间隔（秒，0 关闭）。
# PIPELINE_PROGRESS_INTERVAL=20

# 各阶段默认引擎：claude | codex | gemini | cursor（飞书发"需求@xxx"可按需求覆盖）
# PIPELINE_ENGINE_CLARIFY=claude
# PIPELINE_ENGINE_CODE=cursor
# PIPELINE_ENGINE_REVIEW=gemini

# —— 禅道 Bug 导入（可选）——
# 也可以复制 zentao.example.json 为 zentao.json 配置。
# ZENTAO_BASE_URL=https://zentao.example.com
# ZENTAO_TOKEN=
# ZENTAO_ACCOUNT=
# ZENTAO_PASSWORD=
# ZENTAO_WORKSPACE=
# ZENTAO_AGENT=

# 数据层（lark.py）只依赖上面的 FEISHU 凭据 + Base 标识，已不再需要 hermes。
# 入站（收飞书消息）使用 listener.py + 官方 lark-oapi SDK 长连接；不要同时启动 hermes gateway，
# 否则同一个飞书 app 的长连接事件可能被分流。
